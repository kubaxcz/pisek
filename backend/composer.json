{
  "name": "piskari/backend",
  "type": "project",
  "require": {
    "php": ">=8.2",
    "ext-pdo": "*",
    "ext-dom": "*",
    "ext-libxml": "*",
    "ext-mbstring": "*",
    "ext-curl": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "friendsofphp/php-cs-fixer": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "Piskari\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Piskari\\Tests\\": "tests/"
    }
  },
  "config": {
    "platform": {
      "php": "8.2.0"
    }
  },
  "scripts": {
    "test": "phpunit -c phpunit.xml",
    "lint": "php-cs-fixer fix --allow-risky=yes --dry-run --diff"
  }
}
