DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=piskari
DB_USER=root
DB_PASSWORD=

# Google sign-in: the OAuth 2.0 Web client ID (public).
# Create it in Google Cloud Console and authorise your site origins.
GOOGLE_CLIENT_ID=

# Comma-separated whitelist of e-mails that get admin (scraping) access.
ADMIN_EMAILS=

# Comma-separated allowed origins for CORS ("*" allows any).
CORS_ALLOW_ORIGIN=*
